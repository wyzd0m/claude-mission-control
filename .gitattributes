# Normalize all text files to LF in the repository and on checkout, so
# formatting checks behave identically on Windows, macOS, and Linux.
* text=auto eol=lf

# Windows batch files must use CRLF or cmd.exe can misparse them.
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.mcpb binary
*.zip binary
